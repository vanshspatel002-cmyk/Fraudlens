# Frontend
# Leave blank in Vite dev to use the /api proxy. Set this when Flask is hosted elsewhere.
VITE_API_BASE_URL=

# Backend
LOG_LEVEL=INFO
FLASK_DEBUG=0
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
SERPAPI_KEY=

# Optional when the Flask backend is behind a public HTTPS URL.
# SerpAPI reverse image search requires a publicly reachable image URL;
# localhost/127.0.0.1 cannot be fetched by SerpAPI.
PUBLIC_BASE_URL=https://your-public-flask-backend.example.com

# Cloudflare Worker deployment
# Set as a Worker variable/secret so same-origin /api/* can proxy to Flask.
API_BASE_URL=https://your-flask-backend.example.com
